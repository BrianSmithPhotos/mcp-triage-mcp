# Streamable HTTP endpoint of the planner-mcp server started via the root docker-compose.yml
PLANNER_MCP_URL=http://localhost:8000/mcp

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TRIAGE_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.6

# Must match the plan/bucket names exactly as they appear in Planner
MESSAGE_CENTER_PLAN_NAME=Message Center Posts
TODO_BUCKET_NAME=To Do
FALLBACK_BUCKET_NAME=To Be Deleted

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
