# Used by docker-compose to run the aixolotl/microsoft-planner-mcp server.
# See https://github.com/aixolotl/microsoft-planner-mcp for how to create these
# via an Azure Entra ID app registration.
PLANNER_CLIENT_ID=your-app-client-id
PLANNER_CLIENT_SECRET=your-app-client-secret
PLANNER_TENANT_ID=your-azure-tenant-id
PLANNER_BASE_URL=http://localhost:8000
PLANNER_ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:6274"]
PLANNER_REQUIRE_AUTHORIZATION_CONSENT=true
